# ch-jwt-verify sidecar image. Built by scripts/build-ch-jwt-verify-image.sh
# the same way as the main image: cross-compile a statically-linked binary
# into the context, then docker build with legacy DOCKER_BUILDKIT=0.
FROM alpine:latest

RUN apk --no-cache add ca-certificates

WORKDIR /bin/
COPY ch-jwt-verify .

EXPOSE 9999

ENTRYPOINT ["/bin/ch-jwt-verify"]
