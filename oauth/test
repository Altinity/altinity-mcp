#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="${SCRIPT_DIR}/.."
source "${SCRIPT_DIR}/common.sh"
load_oauth_local_config

ACTION="test"
MCP_JSON="${PROJECT_DIR}/.mcp.json"

usage() {
  cat <<'EOF'
Usage: oauth/test <codex|claude> <forward|gating> [login]

  oauth/test codex forward             Codex batch query
  oauth/test codex gating              Codex batch query
  oauth/test claude gating login       Interactive session to complete OAuth
  oauth/test claude gating             Batch query (requires prior login)
EOF
}

if [[ $# -lt 2 || $# -gt 3 ]]; then
  usage >&2
  exit 1
fi

CLIENT="$1"
MODE="$2"
if [[ $# -ge 3 ]]; then
  ACTION="$3"
fi

case "${CLIENT}" in
  codex|claude)
    ;;
  *)
    echo "Unsupported client: ${CLIENT}" >&2
    usage >&2
    exit 1
    ;;
esac

case "${MODE}" in
  forward)
    URL_SUFFIX="http-f"
    SERVER_NAME="altinity_mcp_oauth_forward"
    ;;
  gating)
    URL_SUFFIX="http-t"
    SERVER_NAME="altinity_mcp_oauth_gating"
    ;;
  *)
    echo "Unsupported mode: ${MODE}" >&2
    usage >&2
    exit 1
    ;;
esac

case "${ACTION}" in
  test|login)
    ;;
  *)
    echo "Unsupported action: ${ACTION}" >&2
    usage >&2
    exit 1
    ;;
esac

SERVER_URL="https://${MCP_TARGET_HOST}/${URL_SUFFIX}"
PROMPT="Use the configured MCP server named ${SERVER_NAME}. Execute SELECT version() and return only the SQL result."

# --- .mcp.json save / restore ---
SAVED_MCP_JSON=""
save_mcp_json() {
  if [[ -f "${MCP_JSON}" ]]; then
    SAVED_MCP_JSON="$(<"${MCP_JSON}")"
  fi
}

restore_mcp_json() {
  if [[ -n "${SAVED_MCP_JSON}" ]]; then
    printf '%s\n' "${SAVED_MCP_JSON}" > "${MCP_JSON}"
  elif [[ -f "${MCP_JSON}" ]]; then
    rm -f "${MCP_JSON}"
  fi
}

write_mcp_json() {
  cat > "${MCP_JSON}" <<MCPEOF
{
  "mcpServers": {
    "${SERVER_NAME}": {
      "type": "http",
      "url": "${SERVER_URL}"
    }
  }
}
MCPEOF
}

case "${CLIENT}" in
  codex)
    codex mcp remove "${SERVER_NAME}" >/dev/null 2>&1 || true
    codex mcp add "${SERVER_NAME}" --url "${SERVER_URL}"
    if [[ "${ACTION}" == "login" ]]; then
      codex mcp login "${SERVER_NAME}"
    else
      codex exec "${PROMPT}"
    fi
    ;;
  claude)
    save_mcp_json
    trap restore_mcp_json EXIT
    write_mcp_json

    if [[ "${ACTION}" == "login" ]]; then
      echo "Starting interactive Claude session to complete OAuth login..."
      echo "Approve the MCP server when prompted, then type /quit to exit."
      echo ""
      claude
    else
      claude -p "${PROMPT}"
    fi
    ;;
esac
